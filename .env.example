# ---- Telegram ----
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your numeric Telegram user id (see README). Only this user can use the bot.
TELEGRAM_ALLOWED_USER_ID=123456789

# ---- Time zone & reminders (SPEC-004) ----
# IANA timezone name used to interpret event dates and to schedule the bot's
# "day before" reminders. Example: Europe/Moscow, Europe/Berlin, UTC.
APP_TIMEZONE=UTC
# Local time (HH:MM, in APP_TIMEZONE) when the bot sends the reminder listing
# the next day's events.
REMINDER_TIME=20:00

# ---- Web login (single user) ----
WEB_LOGIN=admin
WEB_PASSWORD=change-me

# ---- Session signing key ----
# Generate a long random value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ---- Domain (production / Caddy only) ----
# Leave empty for local testing with docker-compose.local.yml
DOMAIN=tasks.example.com
